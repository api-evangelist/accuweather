      "nullable": true
    },
    "categories": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "nullable": true
    },
    "productQuality": {
      "type": "string",
      "nullable": true
    },
    "context": {
      "type": "string",
      "nullable": true
    },
    "keywords": {
      "type": "string",
      "nullable": true
    },
    "sourceRelationship": {
      "enum": [
        "Indirect",
        "Direct"
      ],
