    "fullDayOfWeek": {
      "type": "string",
      "nullable": true
    },
    "epoch": {
      "type": "integer",
      "format": "int32",
      "nullable": true
    },
    "dateTime": {
      "type": "string",
      "nullable": true
    },
    "displayDate": {
      "type": "string",
      "nullable": true
    },
    "longDisplayDate": {
      "type": "string",
      "nullable": true
